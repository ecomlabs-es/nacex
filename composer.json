{
  "name": "prestashop/nacex",
  "description": "PrestaShop module Nacex",
  "homepage": "https://www.nacex.es",
  "license": "AFL - Academic Free License (AFL 3.0)",
  "authors": [
    {
      "name": "Nacex Developement"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "PrestaShop\\Module\\Nacex\\": "src/"
    },
    "exclude-from-classmap": []
  },
  "config": {
    "preferred-install": "dist",
    "prepend-autoloader": false,
    "platform": {
      "php": "7.4.0"
    },
    "allow-plugins": {
      "phpstan/extension-installer": true
    },
    "audit": {
      "block-insecure": false
    }
  },
  "scripts": {
    "test": "@test:unit",
    "test:unit": "phpunit --testsuite unit",
    "lint": [
      "@lint:php",
      "@lint:cs"
    ],
    "lint:php": "find . -name '*.php' -not -path './vendor/*' -not -path './tests/*' | xargs -n1 php -l -q",
    "lint:cs": "php-cs-fixer fix --dry-run --diff",
    "fix:cs": "php-cs-fixer fix",
    "stan": "phpstan analyse --memory-limit=256M",
    "qa": [
      "@lint:php",
      "@stan",
      "@test:unit"
    ]
  },
  "type": "prestashop-module"
}
